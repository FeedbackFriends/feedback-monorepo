{
  "name": "feedback-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "20.19.0"
  },
  "scripts": {
    "dev": "dotenv -e ../.env -- next dev",
    "build": "dotenv -e ../.env -- next build",
