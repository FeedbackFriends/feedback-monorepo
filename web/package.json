    "framer-motion": "12.36.0",
    "lucide-react": "^0.468.0",
    "next": "16.1.7",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@next/eslint-plugin-next": "16.1.6",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^22.10.1",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.12.0",
